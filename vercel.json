{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/chat.mjs", "use": "@vercel/node" },
    { "src": "api/notify.mjs", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.mjs" },
    { "src": "/api/notify", "dest": "/api/notify.mjs" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
